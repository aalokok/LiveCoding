//url- https://hydra.ojack.xyz/?%3D%3D


await navigator.mediaDevices.getUserMedia({ audio: true, video: true })
s0.initCam()
a.setScale(12)

src(s0)
  .scale(1, 0.75) // 
  .saturate(1)
  .contrast(1.6)
  .luma(0.4, 0.3)
  .out(o1)
src(o0)
  .scale(() => 0.8)                    
  .modulate(
    src(o0)
      .rotate(() => time * 0.003)
      .scale(0.97),
    () => 0.007 + a.fft[1] * 0.0005      
  )
  .brightness(-0.005)                    
  .add(
    src(o1)
      .modulate(
        osc(() => 30 + a.fft[2] * 40, 0.0, 0)
          .rotate(() => time * 0.5),
        () => 0.006 + a.fft[0] * 0.018
      )
      .contrast(() => 1.8 + a.fft[3] * 1.2)
      .brightness(-0.1)
      .color(0.9, 0.95, 1.0),
    () => 0.35 + a.fft[1] * 0.3
  )
  .saturate(1)
  .contrast(() => 1.2 + a.fft[2] * 0.4)
  .out(o0)
