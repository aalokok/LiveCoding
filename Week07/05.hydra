a.setScale(7);
shape(16.498, 0.12, 0.22)
	.color(0.5, 0.36, 10)
	.scale(() => Math.sin(time * 0.1) * 1 + 2)
	.repeat(() => Math.sin(time * 0.091) * 0.183 + a.fft[1] * 3, () => Math.sin(time * 0.07) * 3 + a.fft[1] * 3)
	.modulateRotate(o0, () => 0.024 + a.fft[0] * 0.5)
	.scale(() => Math.sin(time * 0.007) * 0.2 + 1.2)
	.modulate(noise(() => 1.2 + a.fft[2] * 1.2, () => 0.8 + a.fft[3] * 0.8))
	.rotate(1, () => 0.018 + a.fft[0] * 0.12)
	.brightness(() => -0.008 - a.fft[0] * 0.008)
	.out(o0);
